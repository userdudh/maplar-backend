generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id    String @id @default(uuid())
  nome  String
  email String @unique
  senha String

  imoveis Imovel[]
}

model Imovel {
  id        String @id @default(uuid())
  titulo    String
  valor     Float
  tipo      String
  imagem    String
  descricao String
  quarto    Int
  banheiro  Int

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
}
